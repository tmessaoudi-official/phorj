{
  "name": "phorj",
  "displayName": "Phorj",
  "description": "Phorj language support — syntax highlighting plus diagnostics, hover, go-to-definition, completion, document symbols, references, rename, and formatting via the `phg lsp` language server.",
  "version": "0.3.3",
  "publisher": "phorj",
  "license": "MIT OR Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/tmessaoudi-official/phorj" },
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:phorj"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "phorj",
        "aliases": ["Phorj"],
        "extensions": [".phg"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "phorj",
        "scopeName": "source.phorj",
        "path": "./syntaxes/phorj.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Phorj",
      "properties": {
        "phorj.serverPath": {
          "type": "string",
          "default": "phg",
          "description": "Path to the `phg` binary. The language server is started as `phg lsp`."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
