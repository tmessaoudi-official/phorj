# EditorConfig — https://editorconfig.org
# Consistent whitespace across editors. Rust formatting is owned by rustfmt; this covers the rest.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.rs]
indent_size = 4
max_line_length = 100

[*.{md,markdown}]
# Keep trailing whitespace untouched in Markdown (two trailing spaces = hard line break).
trim_trailing_whitespace = false

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.phg]
indent_size = 4

[Makefile]
indent_style = tab
