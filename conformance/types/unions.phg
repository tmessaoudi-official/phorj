// Conformance: union types `A | B` + match-over-union (type patterns).
package Main;

import Core.Output;

class Cash {
    constructor(public int amount) {}
}

class Card {
    constructor(public string number) {}
}

function describe(Cash | Card payment): string {
    return match (payment) { Cash c => "cash {c.amount}", Card k => "card {k.number}" };
}

#[Entry]
function main(): void {
    Output.printLine(describe(new Cash(100)));
    Output.printLine(describe(new Card("4321")));
}
