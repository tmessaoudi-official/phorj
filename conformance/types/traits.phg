// Conformance: traits — horizontal reuse via `use` (a trait method mixed into a class).
package Main;

import Core.Output;

trait Greet {
    function hello(): string {
        return "hello from a trait";
    }
}

trait Taggable {
    function tag(): string {
        return "tagged";
    }
}

class Robot {
    use Greet;
    use Taggable;
}

#[Entry]
function main(): void {
    Robot r = new Robot();
    Output.printLine(r.hello());
    Output.printLine(r.tag());
}
