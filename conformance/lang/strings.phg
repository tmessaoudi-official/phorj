// Conformance: string interpolation, concatenation, escapes, Unicode.
package Main;

import Core.Console;

function main() -> void {
    string name = "Ada";
    int n = 42;
    Console.println("hello, {name}!");
    Console.println("n = {n}, n+1 = {n + 1}");
    Console.println("a" + "b" + "c");
    Console.println("tab\tend");
    Console.println("brace \{literal\}");
    Console.println("\u{2713} done");
}
