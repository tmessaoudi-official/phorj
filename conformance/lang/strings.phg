// Conformance: string interpolation, concatenation, escapes, Unicode.
package Main;

import Core.Output;

#[Entry]
function main(): void {
    string name = "Ada";
    int n = 42;
    Output.printLine("hello, {name}!");
    Output.printLine("n = {n}, n+1 = {n + 1}");
    Output.printLine("a" + "b" + "c");
    Output.printLine("tab\tend");
    Output.printLine("brace \{literal\}");
    Output.printLine("✓ done");
}
