package Acme.Shapes;

// Same package as Rect.phg (folder = package: src/Acme/Shapes/ ⇒ Acme.Shapes), second file.
// `internal` — Rect.phg's `scale` calls this across the file boundary (allowed: same package).
internal function factor(): int {
    // `clamp` is `private` to THIS file — visible here, and only here.
    return clamp(1);
}

// `private` — visible only inside helpers.phg. Rect.phg cannot see it; `main` certainly cannot.
private function clamp(int n): int {
    return n;
}
