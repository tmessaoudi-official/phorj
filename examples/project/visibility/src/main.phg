package Main;

import Core.Output;

// `Rect` is `public`, so this cross-package `import type` is allowed. Its `internal` helper `scale`
// and `private` helper `clamp` are NOT importable here — see README.md for the rejected cases.
import Acme.Shapes.Rect;

function main(): void {
    Rect r = new Rect(3, 4);
    // area() = scale(3 * 4) = scale(12) = 12 * factor() = 12 * clamp(1) = 12 * 1 = 12.
    Output.printLine("area: {r.area()}");
}
