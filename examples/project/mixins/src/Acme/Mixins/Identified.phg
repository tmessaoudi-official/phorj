// A trait with an *abstract requirement* (M-RT S8): the using class must supply `id()`, and the trait
// builds the `tag()` convenience on top of it. Composed cross-package exactly like `Loud`.
package Acme.Mixins;

trait Identified {
    abstract function id(): int;
    function tag(): string {
        // The using class must provide this — the trait does not store the id itself.
        // Built on the required method.
        return "#{this.id()}";
    }
}
