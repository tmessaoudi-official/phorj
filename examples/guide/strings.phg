package Main;
import Core.Console;

function greet(string who) -> string {
    return "Hello, {who}!";
}

function main() {
    string name = "Phorge";
    int n = 3;
    float pi = 3.14;
    Console.println("name = {name}, n = {n}, pi = {pi}");
    Console.println("n + 1 = {n + 1}");
    Console.println(greet(name));

    // bind first — the interpolation sub-lexer does not nest string literals inside {…}
    string w = "world";
    Console.println("nested call: {greet(w)}");
}