// Core.Validation — syntactic string predicates (native-stdlib wave).
//
// Format checks, each `string -> bool`: `isInt`, `isNumber` (int or fixed-point), `isAlpha`,
// `isAlnum`, `isHex`, plus the ctype character-class predicates `isLower`, `isUpper`,
// `isWhitespace`, `isPunctuation`, `isControl`, `isVisible` (printable non-space), `isPrintable`,
// and the composite `isEmail` / `isUrl` shape checks.
// Phorj is std-only (no regex crate), so each check is hand-rolled in Rust; the transpiled PHP uses
// the *same* anchored `preg_match` pattern (the class predicates add the `D`/dollar-end-only flag) —
// byte-identical by construction. These check shape, not range (e.g. `isInt("007")` is true). Every
// predicate returns false on the empty string.
package Main;

import Core.Output;
import Core.Validation;
import Core.Runtime.Entry;

function report(string label, bool ok): void {
    Output.printLine("{label}: {ok}");
}

#[Entry]
function main(): void {
    report("isInt(-42)", Validation.isInt("-42"));
    report("isInt(3.14)", Validation.isInt("3.14"));
    report("isNumber(3.14)", Validation.isNumber("3.14"));
    report("isNumber(.5)", Validation.isNumber(".5"));
    report("isAlpha(Phorj)", Validation.isAlpha("Phorj"));
    report("isAlpha(Phorj9)", Validation.isAlpha("Phorj9"));
    report("isAlnum(abc123)", Validation.isAlnum("abc123"));
    report("isHex(DEADbeef)", Validation.isHex("DEADbeef"));
    report("isHex(0xFF)", Validation.isHex("0xFF"));
    report("isLower(phorj)", Validation.isLower("phorj"));
    report("isLower(Phorj)", Validation.isLower("Phorj"));
    report("isUpper(PHORJ)", Validation.isUpper("PHORJ"));
    report("isWhitespace(tab)", Validation.isWhitespace("\t"));
    report("isWhitespace(a b)", Validation.isWhitespace("a b"));
    report("isPunctuation(!?.)", Validation.isPunctuation("!?."));
    report("isPunctuation(hi!)", Validation.isPunctuation("hi!"));
    report("isControl(tab)", Validation.isControl("\t"));
    report("isControl(abc)", Validation.isControl("abc"));
    report("isVisible(Phorj!)", Validation.isVisible("Phorj!"));
    report("isVisible(a b)", Validation.isVisible("a b"));
    report("isPrintable(Phorj 9!)", Validation.isPrintable("Phorj 9!"));
    report("isEmail(a@b.co)", Validation.isEmail("a@b.co"));
    report("isEmail(user@localhost)", Validation.isEmail("user@localhost"));
    report("isEmail(a..b@c.com)", Validation.isEmail("a..b@c.com"));
    report("isUrl(https://x.io/p)", Validation.isUrl("https://x.io/p"));
    report("isUrl(notaurl)", Validation.isUrl("notaurl"));
}
