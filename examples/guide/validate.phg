// Core.Validation — syntactic string predicates (native-stdlib wave).
//
// Format checks, each `string -> bool`: `isInt`, `isNumber` (int or fixed-point), `isAlpha`,
// `isAlnum`, `isHex`. Phorj is std-only (no regex crate), so each check is hand-rolled in Rust and
// the transpiled PHP uses the *same* anchored pattern via `preg_match` — byte-identical by
// construction. These check shape, not range (e.g. `isInt("007")` is true).
package Main;

import Core.Output;
import Core.Validation;

function report(string label, bool ok): void {
    Output.printLine("{label}: {ok}");
}

#[Entry]
function main(): void {
    report("isInt(-42)", Validation.isInt("-42"));
    report("isInt(3.14)", Validation.isInt("3.14"));
    report("isNumber(3.14)", Validation.isNumber("3.14"));
    report("isNumber(.5)", Validation.isNumber(".5"));
    report("isAlpha(Phorj)", Validation.isAlpha("Phorj"));
    report("isAlpha(Phorj9)", Validation.isAlpha("Phorj9"));
    report("isAlnum(abc123)", Validation.isAlnum("abc123"));
    report("isHex(DEADbeef)", Validation.isHex("DEADbeef"));
    report("isHex(0xFF)", Validation.isHex("0xFF"));
}
