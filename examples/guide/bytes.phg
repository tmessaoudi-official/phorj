package Main;

// M6 W0 ‚Äî the `bytes` type: raw octet sequences distinct from UTF-8 `string`.
// `b"‚Ä¶"` literals (with `\xHH`), and the `Core.Bytes` interop module.
import Core.Console;
import Core.Bytes;

function main() {
  // fromString + len (BYTE count) + toString round-trip.
  bytes hello = Bytes.fromString("hello");
  int n = Bytes.len(hello);
  Console.println("len={n}");                         // len=5
  Console.println(Bytes.toString(hello) ?? "?");     // hello

  // A `b"‚Ä¶"` literal with \xHH escapes ‚Äî 0x48 0x69 = "Hi".
  bytes raw = b"\x48\x69";
  Console.println(Bytes.toString(raw) ?? "?");       // Hi
  int rn = Bytes.len(raw);
  Console.println("rawlen={rn}");                     // rawlen=2

  // Invalid UTF-8 decodes to `null` (never a fault) ‚Äî composes with `??`.
  bytes bad = b"\xff\xfe";
  Console.println(Bytes.toString(bad) ?? "<non-utf8>"); // <non-utf8>

  // concat + slice (half-open, bounds-clamped).
  bytes ab = Bytes.concat(b"foo", b"bar");
  Console.println(Bytes.toString(ab) ?? "?");        // foobar
  int abn = Bytes.len(ab);
  Console.println("ablen={abn}");                     // ablen=6

  bytes sl = Bytes.slice(ab, 1, 4);
  Console.println(Bytes.toString(sl) ?? "?");        // oob

  // start > end clamps to an empty slice (total, no fault).
  bytes empty = Bytes.slice(ab, 5, 2);
  int en = Bytes.len(empty);
  Console.println("slempty={en}");                    // slempty=0

  // byte-vector equality.
  bytes eq1 = b"abc";
  bytes eq2 = Bytes.fromString("abc");
  if (eq1 == eq2) { Console.println("eq"); } else { Console.println("ne"); } // eq
}
