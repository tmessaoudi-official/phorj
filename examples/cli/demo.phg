package Main;

import Core.Output;

// A tiny program used by ../cli/README.md to demonstrate the phorj CLI:
// source forms (file / stdin / inline), inspection (check / parse / lex),
// the diagnostic dictionary (explain), and clean compile/runtime faults.
#[Entry]
function main(): void {
    int n = 6;
    Output.printLine("phorj CLI demo");
    Output.printLine("n doubled = {n * 2}");
}
