package Main;
import Core.Console;

// A tiny program used by ../cli/README.md to demonstrate the phorge CLI:
// source forms (file / stdin / inline), inspection (check / parse / lex),
// the diagnostic dictionary (explain), and clean compile/runtime faults.
function main() {
    int n = 6;
    Console.println("phorge CLI demo");
    Console.println("n doubled = {n * 2}");
}