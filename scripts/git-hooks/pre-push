#!/usr/bin/env bash
# Phorj pre-push gate — the byte-identity SPINE check (developer, 2026-07-03 speed split).
#
# Pre-commit runs the fast Rust-only gate (run == runvm parity + every unit/integration test).
# THIS hook runs the FULL PHP-oracle differential against the 8.5 transpile floor before anything
# is published to the remote: with PHORJ_REQUIRE_PHP=1 a missing php FAILS the run (never silently
# skips), so a push can never bypass the spine check. fmt + clippy re-run too (cheap; a push is the
# publish boundary and may carry --no-verify commits). cargo-nextest is preferred with a fallback
# to plain `cargo test`, same as pre-commit — zero hard dependency.
set -euo pipefail

# git feeds the pushed-ref list on stdin; we gate the whole push, not per-ref, so drain it.
cat >/dev/null || true

# The toolchain lives outside the default PATH on this machine; prepend it only if cargo is
# not already reachable (keeps the hook working under git's reduced environment).
command -v cargo >/dev/null 2>&1 || export PATH="/stack/tools/cargo/bin:$PATH"

# Gate against the 8.5 transpile floor (NOT the 8.6-dev php on PATH). A missing php FAILS.
export PHORJ_PHP="/stack/tools/phpbrew/php/php-8.5.7/bin/php"
export PHORJ_REQUIRE_PHP=1

echo "[pre-push] cargo fmt --check"
cargo fmt --check

echo "[pre-push] cargo clippy --all-targets -- -D warnings"
cargo clippy --all-targets -- -D warnings

if cargo nextest --version >/dev/null 2>&1; then
  echo "[pre-push] cargo nextest run (full PHP oracle, 8.5 floor)"
  cargo nextest run --status-level fail
  echo "[pre-push] cargo test --doc"
  cargo test --doc --quiet
else
  echo "[pre-push] cargo test (nextest absent — fallback, full PHP oracle)"
  cargo test --quiet
fi

echo "[pre-push] OK"
