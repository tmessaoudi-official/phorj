#!/usr/bin/env bash
# Phorj pre-push gate — the byte-identity SPINE check (developer, 2026-07-03 speed split).
#
# Pre-commit runs the fast Rust-only gate (fast tier: run == runvm parity + every unit/integration
# test EXCEPT the two heavy sweeps). THIS hook runs the FULL suite — including those two sweeps
# (`every_repo_phg_formats_idempotently_and_safely` + `shipped_manual_example_runs_on_both_backends`)
# — plus the PHP-oracle differential against the 8.5 transpile floor before anything is published:
# with PHORJ_REQUIRE_PHP=1 a missing php FAILS the run (never silently skips), so a push can never
# bypass the spine check. `--features jit` gates the JIT backend (not a default feature). `clippy`
# lives HERE now (moved off pre-commit 2026-07-08 — a lint is zero correctness-risk and batches
# cleanly at this ~10-20-commit boundary); both feature configs are linted. cargo-nextest is preferred
# with a `cargo test` fallback — zero hard dependency.
set -euo pipefail

# git feeds the pushed-ref list on stdin; we gate the whole push, not per-ref, so drain it.
cat >/dev/null || true

# The toolchain lives outside the default PATH on this machine; prepend it only if cargo is
# not already reachable (keeps the hook working under git's reduced environment).
command -v cargo >/dev/null 2>&1 || export PATH="/stack/tools/cargo/bin:$PATH"

# Build NON-incrementally for the gate. This box links with `mold` (machine-local, gitignored
# config), and `mold` + rustc incremental compilation intermittently fail to link with
# `undefined symbol: anon.<hash>.llvm.<n>` referencing stale `*.rcgu.o` incremental codegen units —
# a known mold+incremental interaction, triggered whenever an earlier build was interrupted and left
# stale units behind. It is NOT a code error (the same tree links + tests clean non-incrementally).
# The pre-push gate is a full-suite build where incremental buys little, so disabling it here makes
# the gate robust against the corruption without slowing the fast pre-commit tier (which keeps
# incremental). Root cause: stale incremental units; fix: from-scratch codegen (no stale units).
export CARGO_INCREMENTAL=0

# Gate against the 8.5 transpile floor (NOT the 8.6-dev php on PATH). A missing php FAILS.
# The oracle path is configured in scripts/toolchain.env (edit there when the stack php version
# changes); resolve it via the repo root so this works whichever way the hook is invoked.
_gate_root="$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
# shellcheck source=/dev/null
[[ -f "$_gate_root/scripts/toolchain.env" ]] && source "$_gate_root/scripts/toolchain.env"
export PHORJ_PHP="${PHORJ_PHP:-/stack/tools/phpbrew/php/php-8.5.8/bin/php}"
export PHORJ_REQUIRE_PHP=1

echo "[pre-push] cargo fmt --check"
cargo fmt --check

# File-size gate (Invariant 13 — developer-ruled 2026-07-20). Ratchet: new files capped at 500,
# the 90 pre-existing breaches grandfathered in scripts/size-baseline.txt (may only shrink), soft
# warn at 300. Cheap (line counts) — runs early. Detail: scripts/size-gate.sh.
echo "[pre-push] size-gate (Invariant 13 file-size ratchet)"
bash "$_gate_root/scripts/size-gate.sh"

# Lint the two ends of the feature spectrum (developer-ruled 2026-07-16 — the standing gate is
# ALL-FEATURES). `--all-features` compiles + lints EVERY shipped surface (jit, database, database-postgres,
# database-mysql, mail, http-client) — the old `--features jit`-only gate never touched those files, hiding
# real clippy lints (caught: http_client.rs, db/mysql.rs collapsible-ifs). `--no-default-features`
# lints the minimal/jit-off path. Together they bound every config a change can land in.
echo "[pre-push] cargo clippy --all-targets --no-default-features -- -D warnings"
cargo clippy --all-targets --no-default-features -- -D warnings
echo "[pre-push] cargo clippy --all-targets --all-features -- -D warnings"
cargo clippy --all-targets --all-features -- -D warnings

# FULL suite under --all-features + the PHP oracle. `--all-features` SUBSUMES the old separate
# `--features database` step (database is now in the set) and adds the previously-ungated http-client/mail/postgres/
# mysql surfaces. The live DB/mail/http round-trips self-skip when their `PHORJ_*_TEST_DSN` / server env
# is absent (skip-loud, never silently green), so the gate needs no live servers.
if cargo nextest --version >/dev/null 2>&1; then
  echo "[pre-push] cargo nextest run --all-features (FULL suite + PHP oracle, 8.5 floor)"
  cargo nextest run --all-features --status-level fail
  echo "[pre-push] cargo test --doc --all-features"
  cargo test --doc --all-features --quiet
else
  echo "[pre-push] cargo test --all-features (nextest absent — fallback, FULL suite + PHP oracle)"
  cargo test --all-features --quiet
fi

# Release build gate (developer-ruled 2026-07-20; CLAUDE.md "build release after each feature").
# Catches release-profile-only breakage (a debug-only cfg, an opt-level panic) that the dev/test
# profiles above would pass green. Runs after the suite so a red test fails faster/cheaper first.
echo "[pre-push] cargo build --release"
cargo build --release

echo "[pre-push] microbench-gate (G-8 mandate ratchet — no WIN->LOSS flip, output-identity holds)"
# Self-skips (exit 0) if docker or the release binary is absent — a push is never wedged by missing
# infra. Blocks (exit 1) only on a WIN->LOSS flip (a feature that beat release-php now loses) or a
# VM-vs-php output-identity break — both load-insensitive. VM-perf regression is gated robustly by
# perf-gate.sh (same-process tree÷VM). Ratchet: after the JIT lands a WIN, run
# `bash scripts/microbench-gate.sh --emit` so the flip check protects it.
bash "$_gate_root/scripts/microbench-gate.sh"

echo "[pre-push] OK"
