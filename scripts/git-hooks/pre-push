#!/usr/bin/env bash
# Phorj pre-push gate — the byte-identity SPINE check (developer, 2026-07-03 speed split).
#
# Pre-commit runs the fast Rust-only gate (fast tier: run == runvm parity + every unit/integration
# test EXCEPT the two heavy sweeps). THIS hook runs the FULL suite — including those two sweeps
# (`every_repo_phg_formats_idempotently_and_safely` + `shipped_manual_example_runs_on_both_backends`)
# — plus the PHP-oracle differential against the 8.5 transpile floor before anything is published:
# with PHORJ_REQUIRE_PHP=1 a missing php FAILS the run (never silently skips), so a push can never
# bypass the spine check. `--features jit` gates the JIT backend (not a default feature). `clippy`
# lives HERE now (moved off pre-commit 2026-07-08 — a lint is zero correctness-risk and batches
# cleanly at this ~10-20-commit boundary); both feature configs are linted. cargo-nextest is preferred
# with a `cargo test` fallback — zero hard dependency.
set -euo pipefail

# git feeds the pushed-ref list on stdin; we gate the whole push, not per-ref, so drain it.
cat >/dev/null || true

# The toolchain lives outside the default PATH on this machine; prepend it only if cargo is
# not already reachable (keeps the hook working under git's reduced environment).
command -v cargo >/dev/null 2>&1 || export PATH="/stack/tools/cargo/bin:$PATH"

# Gate against the 8.5 transpile floor (NOT the 8.6-dev php on PATH). A missing php FAILS.
# The oracle path is configured in scripts/toolchain.env (edit there when the stack php version
# changes); resolve it via the repo root so this works whichever way the hook is invoked.
_gate_root="$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
# shellcheck source=/dev/null
[[ -f "$_gate_root/scripts/toolchain.env" ]] && source "$_gate_root/scripts/toolchain.env"
export PHORJ_PHP="${PHORJ_PHP:-/stack/tools/phpbrew/php/php-8.5.8/bin/php}"
export PHORJ_REQUIRE_PHP=1

echo "[pre-push] cargo fmt --check"
cargo fmt --check

# Lint both feature configs (default + jit) — the JIT code is only compiled under `--features jit`,
# and pre-commit no longer runs clippy, so this is the sole clippy gate.
echo "[pre-push] cargo clippy --all-targets -- -D warnings"
cargo clippy --all-targets -- -D warnings
echo "[pre-push] cargo clippy --all-targets --features jit -- -D warnings"
cargo clippy --all-targets --features jit -- -D warnings

if cargo nextest --version >/dev/null 2>&1; then
  echo "[pre-push] cargo nextest run --features jit (FULL suite + PHP oracle, 8.5 floor)"
  cargo nextest run --features jit --status-level fail
  echo "[pre-push] cargo test --doc --features jit"
  cargo test --doc --features jit --quiet
else
  echo "[pre-push] cargo test --features jit (nextest absent — fallback, FULL suite + PHP oracle)"
  cargo test --features jit --quiet
fi

echo "[pre-push] microbench-gate (G-8 mandate ratchet — no WIN->LOSS flip, output-identity holds)"
# Self-skips (exit 0) if docker or the release binary is absent — a push is never wedged by missing
# infra. Blocks (exit 1) only on a WIN->LOSS flip (a feature that beat release-php now loses) or a
# VM-vs-php output-identity break — both load-insensitive. VM-perf regression is gated robustly by
# perf-gate.sh (same-process tree÷VM). Ratchet: after the JIT lands a WIN, run
# `bash scripts/microbench-gate.sh --emit` so the flip check protects it.
bash "$_gate_root/scripts/microbench-gate.sh"

echo "[pre-push] OK"
