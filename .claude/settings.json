{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(cargo:*)",
      "Bash(docker run --rm:*)",
      "Bash(source scripts/toolchain.env:*)",
      "Bash(./target/release/phg:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/claude-bootstrap/install.sh"
          }
        ]
      }
    ]
  }
}
